.an-badge{background:var(--accent);color:#fff;padding:3px 12px;border-radius:50px;font-size:12px;font-weight:700;}
.macro-btns{display:flex;gap:6px;flex-wrap:wrap;}
.mbtn{padding:7px 13px;border-radius:7px;font-size:11px;font-weight:700;border:none;cursor:pointer;font-family:'Outfit',sans-serif;transition:opacity .2s,transform .15s;}
.mbtn:hover{opacity:.85;transform:translateY(-1px);}
.mb-o{background:#E65100;color:#fff;}.mb-b{background:var(--bleu3);color:#fff;}.mb-g{background:#2E7D32;color:#fff;}.mb-p{background:#6A1B9A;color:#fff;}.mb-r{background:#C62828;color:#fff;}
.lock-bar{background:rgba(198,40,40,.12);border-bottom:1px solid rgba(198,40,40,.3);padding:8px 16px;font-size:12px;color:rgba(255,130,130,.9);display:flex;align-items:center;gap:8px;}
.sync-bar{background:rgba(30,136,229,.1);border-bottom:1px solid rgba(30,136,229,.2);padding:6px 16px;font-size:11px;color:rgba(100,180,255,.8);display:flex;align-items:center;gap:8px;}
table.tm{width:100%;border-collapse:collapse;min-width:700px;font-size:12px;}
