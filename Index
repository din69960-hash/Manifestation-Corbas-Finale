.confirm-box{background:#fff;color:var(--texte);border-radius:18px;padding:32px 28px;width:100%;max-width:380px;text-align:center;animation:popIn .3s cubic-bezier(.34,1.56,.64,1) both;box-shadow:0 20px 60px rgba(0,0,0,.4);}
.confirm-box h3{font-size:18px;font-weight:700;color:#C62828;margin-bottom:10px;}
.confirm-box p{font-size:13.5px;color:#4A5568;line-height:1.6;margin-bottom:24px;}
.confirm-btns{display:flex;gap:12px;justify-content:center;}
.confirm-btns button{padding:10px 24px;border-radius:10px;font-size:14px;font-weight:600;border:none;cursor:pointer;font-family:'Outfit',sans-serif;}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:11px 24px;position:sticky;top:0;z-index:50;flex-wrap:wrap;gap:8px;}
.topbar.blue{background:var(--bleu);}.topbar.dark{background:#0A1628;border-bottom:1px solid rgba(255,255,255,.08);}
.topbar.light{background:#fff;border-bottom:1px solid #E2E8F0;color:var(--texte);}
.topbar h1{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;}
.topbar.light h1{color:var(--bleu);}
.btn-back{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;padding:6px 16px;border-radius:50px;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;transition:background .2s;}
.btn-back:hover{background:rgba(255,255,255,.22);}
.btn-back-light{background:var(--gris);border:1px solid #E2E8F0;color:var(--texte);padding:6px 16px;border-radius:50px;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;}
.planning-shell{display:flex;flex-direction:column;height:calc(100vh - 52px);}
.tabs-zone{flex-shrink:0;position:relative;}.table-zone{flex:1;overflow:auto;}
.tabs-wrapper{position:relative;background:#0A1628;padding:10px 44px 0;}
.tabs-bar{display:flex;overflow-x:hidden;gap:3px;scrollbar-width:none;transition:scroll .2s;}
.tabs-bar::-webkit-scrollbar{display:none;}
.tabs-bar .tab{flex-shrink:0;padding:7px 13px;border-radius:7px 7px 0 0;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:'Outfit',sans-serif;background:rgba(255,255,255,.07);color:rgba(255,255,255,.5);transition:background .2s,color .2s;white-space:nowrap;}
