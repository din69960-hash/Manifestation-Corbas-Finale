.modal{background:#fff;color:var(--texte);border-radius:22px;padding:38px 34px;width:100%;max-width:420px;position:relative;animation:popIn .35s cubic-bezier(.34,1.56,.64,1) both;box-shadow:0 30px 80px rgba(0,0,0,.4);}
