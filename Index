<script>
const SUPABASE_URL = 'https://nvufzwdwhearlwdcezsn.supabase.co';
const SUPABASE_KEY = 'sb_publishable_Ts29xuGykGP-xQ7R5ldKYg_J8Ywxnwl';
// Identifiant unique de cet onglet/navigateur : permet d'ignorer ses propres mises à jour temps réel
const CLIENT_ID = Math.random().toString(36).slice(2) + Date.now().toString(36);
let supabaseClient = null;
let useDB = false;
let pendingRemote = false; // une mise à jour distante attend que l'utilisateur finisse de taper

async function initSupabase(){
  try {
    const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm');
    supabaseClient = createClient(SUPABASE_URL, SUPABASE_KEY);
    const { error } = await supabaseClient.from('planning').select('id').limit(1);
    if(error) throw error;
    useDB = true; setDBStatus('ok'); await loadFromDB();
    subscribeRealtime();
  } catch(e){ console.warn('Supabase erreur:', e.message); setDBStatus('err'); }
}

// ===== TEMPS RÉEL : reçoit les modifications des autres utilisateurs =====
function subscribeRealtime(){
  supabaseClient.channel('planning-realtime')
    .on('postgres_changes',
      { event:'*', schema:'public', table:'planning', filter:'id=eq.main' },
      (p)=>{ if(p.new && p.new.payload) applyRemote(p.new.payload); })
    .subscribe((status)=>{ if(status==='SUBSCRIBED') setDBStatus('live'); });
}

function applyRemote(d){
  if(!d || d._client === CLIENT_ID) return; // ignorer nos propres sauvegardes
  if(d.mois) S.mois=d.mois; if(d.act) S.act=d.act; if(d.acts_list) S.acts_list=d.acts_list;
  if(d.verrou!==undefined) S.verrou=d.verrou; if(d.annee) S.annee=d.annee;
  if(d.mdpAsso) S.mdpAsso=d.mdpAsso; if(d.mdpAdmin) S.mdpAdmin=d.mdpAdmin;
  saveLocal();
  // Si l'utilisateur est en train de taper dans une cellule, on n'interrompt pas :
  // les données sont à jour en mémoire, le rafraîchissement visuel attendra la fin de saisie
  const ae=document.activeElement;
  const editing = ae && (ae.tagName==='TEXTAREA'||ae.tagName==='INPUT') && (ae.classList.contains('ei')||ae.classList.contains('aei'));
  if(editing){ pendingRemote=true; return; }
  refreshCurrentView(true);
}

// Quand l'utilisateur quitte une cellule, applique la mise à jour distante en attente
document.addEventListener('focusout',()=>{ setTimeout(()=>{
  if(!pendingRemote) return;
  const ae=document.activeElement;
  const editing = ae && (ae.tagName==='TEXTAREA'||ae.tagName==='INPUT') && (ae.classList.contains('ei')||ae.classList.contains('aei'));
  if(!editing){ pendingRemote=false; refreshCurrentView(true); }
},200); });

function refreshCurrentView(notify){
  if(document.getElementById('pg-asso').classList.contains('active')){
    document.getElementById('asso-lock-bar').style.display=S.verrou?'flex':'none';
    rebuildTabsKeep('asso-tabs-zone','asso-content',false);
  }
  if(document.getElementById('pg-admin-planning').classList.contains('active')){
    rebuildTabsKeep('admin-tabs-zone','admin-content',true);
  }
  if(document.getElementById('pg-bilan').classList.contains('active')) renderBilan();
  if(document.getElementById('pg-verrou').classList.contains('active')) majVerrou();
  if(notify) toast('🔄 Mise à jour reçue d\'un autre utilisateur');
}

// Reconstruit les onglets en conservant l'onglet actuellement sélectionné
function rebuildTabsKeep(zoneId,cid,isAdmin){
  const keep=currentIdx;
  buildTabs(zoneId,cid,isAdmin);
  const bar=document.getElementById('tabs-bar-'+zoneId);
  if(!bar) return;
  const tabs=bar.querySelectorAll('.tab');
  const idx=Math.min(keep,tabs.length-1);
  if(idx>0 && tabs[idx]){
    tabs.forEach(t=>t.classList.remove('active'));
    tabs[idx].classList.add('active');
    currentIdx=idx;
    renderTab(cid,idx,isAdmin);
  }
}

function setDBStatus(s){
  const el=document.getElementById('db-status');
  if(s==='live'){el.className='db-status db-ok';el.textContent='🟢 Synchro temps réel active';}
  else if(s==='ok'){el.className='db-status db-ok';el.textContent='🟢 Base de données partagée';}
  else if(s==='local'){el.className='db-status db-local';el.textContent='💾 Stockage local';}
  else{el.className='db-status db-err';el.textContent='🔴 Erreur BDD — mode local';}
  const shared=(s==='ok'||s==='live');
  const msg=s==='live'?'🟢 Temps réel actif — les modifications des autres apparaissent automatiquement'
    :(s==='ok'?'🟢 Données partagées — visibles par tous':'⚠️ Mode local — données non partagées');
  ['asso','admin'].forEach(t=>{const b=document.getElementById('sync-bar-'+t);if(b){b.textContent=msg;b.style.background=shared?'rgba(46,125,50,.15)':'rgba(180,100,0,.12)';}});
}

async function loadFromDB(){
  if(!useDB) return;
  try {
    const {data,error}=await supabaseClient.from('planning').select('*').eq('id','main').single();
    if(error||!data) return;
    const d=data.payload;
    if(d.mois) S.mois=d.mois; if(d.act) S.act=d.act; if(d.acts_list) S.acts_list=d.acts_list;
    if(d.verrou!==undefined) S.verrou=d.verrou; if(d.annee) S.annee=d.annee;
    if(d.mdpAsso) S.mdpAsso=d.mdpAsso; if(d.mdpAdmin) S.mdpAdmin=d.mdpAdmin;
    saveLocal();
    toast('✅ Données chargées depuis la base partagée !');
  } catch(e){ console.warn('loadFromDB error:',e); }
}

async function saveToDB(){
  if(!useDB){saveLocal();return;}
  saveLocal();
  try {
    const{error}=await supabaseClient.from('planning').upsert({
      id:'main',
      payload:{mois:S.mois,act:S.act,acts_list:S.acts_list,verrou:S.verrou,annee:S.annee,mdpAsso:S.mdpAsso,mdpAdmin:S.mdpAdmin,_client:CLIENT_ID},
      updated_at:new Date().toISOString()
    });
    if(error) throw error;
  } catch(e){ console.warn('saveToDB error:',e); setDBStatus('err'); }
}

function saveLocal(){
  try{
    localStorage.setItem('mois_data',JSON.stringify(S.mois));
    localStorage.setItem('act_data',JSON.stringify(S.act));
    localStorage.setItem('acts_list',JSON.stringify(S.acts_list));
    localStorage.setItem('verrou',S.verrou);
    localStorage.setItem('annee',S.annee);
    localStorage.setItem('mdp_asso',S.mdpAsso);
    localStorage.setItem('mdp_admin',S.mdpAdmin);
  }catch(e){}
}
function saveM(){saveToDB();}
function saveA(){saveToDB();}
