.ei{background:transparent;border:none;color:rgba(255,255,255,.88);font-family:'Outfit',sans-serif;font-size:12px;width:100%;padding:5px 7px;outline:none;transition:background .15s;resize:none;display:block;box-sizing:border-box;}
