.inp-code{width:100%;padding:13px 16px;border:2px solid #E2E8F0;border-radius:10px;font-size:20px;font-family:'Outfit',sans-serif;font-weight:700;letter-spacing:6px;text-align:center;outline:none;transition:border .2s;color:var(--texte);}
