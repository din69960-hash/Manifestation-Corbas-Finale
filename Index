.hero-titre{font-family:'Bebas Neue',sans-serif;font-size:clamp(54px,10vw,108px);line-height:.92;text-align:center;letter-spacing:2px;animation:fadeUp .9s ease .2s both;position:relative;z-index:1;}
.hero-titre em{color:var(--accent);font-style:normal;}
.hero-sub{font-size:17px;color:rgba(255,255,255,.65);margin:18px 0 48px;text-align:center;max-width:500px;line-height:1.6;animation:fadeUp .9s ease .4s both;}
.cards-row{display:flex;gap:22px;flex-wrap:wrap;justify-content:center;animation:fadeUp .9s ease .6s both;position:relative;z-index:1;}
.login-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:20px;padding:34px 28px;width:270px;text-align:center;cursor:pointer;transition:transform .3s,background .3s,border-color .3s;backdrop-filter:blur(10px);}
