function calcStats(a){
  let org=0,imp=0,h=0;
  MOIS.forEach(m=>{S.mois[m].rows.forEach(r=>{
    if(r.org&&r.org.toLowerCase().includes(a.toLowerCase())){org++;h+=parseInt(r.dur)||0;}
    if(r.clubs&&r.clubs.toLowerCase().includes(a.toLowerCase())) imp++;
  });});
  return {org,imp,h};
}

