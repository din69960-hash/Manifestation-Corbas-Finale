function initAct(){ S.act={}; S.acts_list.forEach(a=>{if(!S.act[a])S.act[a]=[];}); }
function todayStr(){ const d=new Date(); return d.getDate().toString().padStart(2,'0')+'/'+(d.getMonth()+1).toString().padStart(2,'0')+'/'+d.getFullYear(); }

function go(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
  if(id==='pg-verrou') majVerrou();
  if(id==='pg-bilan') renderBilan();
  if(id==='pg-extraction') buildExtractionBtns();
  if(id==='pg-settings'){document.getElementById('inp-an').value=S.annee;majSaison();}
}
function openModal(t){
  document.getElementById('modal-'+t).classList.add('open');
  const err=document.getElementById('err-'+t);
  if(err) err.style.display='none';
  const inp=document.getElementById('code-'+t)||document.getElementById('new-act-name');
  if(inp){inp.value='';setTimeout(()=>inp.focus(),80);}
}
function closeModal(t){document.getElementById('modal-'+t).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('open');}));

let confirmCallback=null;
function showConfirm(title,msg,cb){
  document.getElementById('confirm-title').textContent=title;
  document.getElementById('confirm-msg').textContent=msg;
  confirmCallback=cb;
  document.getElementById('modal-confirm').classList.add('open');
}
function closeConfirm(){document.getElementById('modal-confirm').classList.remove('open');confirmCallback=null;}
document.getElementById('confirm-ok-btn').addEventListener('click',()=>{closeConfirm();if(confirmCallback)confirmCallback();});

function valAsso(){
  if(document.getElementById('code-asso').value.trim()===S.mdpAsso){
    closeModal('asso');
    buildTabs('asso-tabs-zone','asso-content',false);
    document.getElementById('asso-lock-bar').style.display=S.verrou?'flex':'none';
    go('pg-asso');toast('✅ Connexion réussie !');
  } else {document.getElementById('err-asso').style.display='block';document.getElementById('code-asso').value='';}
}
function valAdmin(){
  if(document.getElementById('code-admin').value.trim()===S.mdpAdmin){
    closeModal('admin');go('pg-admin');toast('✅ Accès administrateur accordé.');
  } else {document.getElementById('err-admin').style.display='block';document.getElementById('code-admin').value='';}
}
function ouvrirPlanningAdmin(){buildTabs('admin-tabs-zone','admin-content',true);go('pg-admin-planning');}

let currentCid='',currentIdx=0,currentIsAdmin=false;

function buildTabs(zoneId,cid,isAdmin){
  const zone=document.getElementById(zoneId);
  let h='<span class="lbl">Mois</span>';
  MOIS.forEach((m,i)=>h+=`<button class="tab${i===0?' active':''}" onclick="swTab('${zoneId}','${cid}',${i},this,${isAdmin})">${m}</button>`);
  h+='<span class="sep"></span><span class="lbl">Activités</span>';
  S.acts_list.forEach((a,i)=>{ const idx=MOIS.length+i; h+=`<button class="tab act-tab" onclick="swTab('${zoneId}','${cid}',${idx},this,${isAdmin})">${a}</button>`; });
  h+=`<button class="tab-add-btn" onclick="openModal('new-act')">＋</button>`;
  h+='<span class="sep"></span>';
  const bi=MOIS.length+S.acts_list.length;
  h+=`<button class="tab bilan-tab" onclick="swTab('${zoneId}','${cid}',${bi},this,${isAdmin})">📊 Bilan</button>`;
  zone.innerHTML=`<div class="tabs-wrapper">
    <button class="tab-arrow tab-arrow-left" onclick="scrollTabs('${zoneId}',-1)">‹</button>
    <div class="tabs-bar" id="tabs-bar-${zoneId}">${h}</div>
    <button class="tab-arrow tab-arrow-right" onclick="scrollTabs('${zoneId}',1)">›</button>
  </div>`;
  currentCid=cid;currentIsAdmin=isAdmin;currentIdx=0;
  renderTab(cid,0,isAdmin);
}
function scrollTabs(zoneId,dir){const b=document.getElementById('tabs-bar-'+zoneId);if(b)b.scrollLeft+=dir*200;}
function swTab(zoneId,cid,idx,btn,isAdmin){
  const b=document.getElementById('tabs-bar-'+zoneId);
  if(b) b.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  currentCid=cid;currentIdx=idx;currentIsAdmin=isAdmin;
  renderTab(cid,idx,isAdmin);
}
function renderTab(cid,idx,isAdmin){
  if(idx<MOIS.length) renderMois(cid,MOIS[idx],isAdmin);
  else if(idx<MOIS.length+S.acts_list.length) renderAct(cid,S.acts_list[idx-MOIS.length],isAdmin);
  else renderBilanInline(cid,isAdmin);
}

function confirmerNouvelleAct(){
  const nom=document.getElementById('new-act-name').value.trim();
  const err=document.getElementById('err-new-act');
  if(!nom||S.acts_list.includes(nom)){err.style.display='block';return;}
  err.style.display='none';
  S.acts_list.push(nom);
  if(!S.act[nom]) S.act[nom]=[];
  saveA();closeModal('new-act');
  if(document.getElementById('pg-asso').classList.contains('active')) buildTabs('asso-tabs-zone','asso-content',false);
  if(document.getElementById('pg-admin-planning').classList.contains('active')) buildTabs('admin-tabs-zone','admin-content',true);
  toast('✅ Activité "'+nom+'" ajoutée !');
}
function supprimerAct(nom){
  showConfirm('⚠️ Supprimer "'+nom+'"','Êtes-vous sûr ? Les données seront perdues.',()=>{
    S.acts_list=S.acts_list.filter(a=>a!==nom);delete S.act[nom];saveA();
    buildTabs(currentIsAdmin?'admin-tabs-zone':'asso-tabs-zone',currentCid,currentIsAdmin);
    toast('🗑️ Onglet "'+nom+'" supprimé.');
  });
}

