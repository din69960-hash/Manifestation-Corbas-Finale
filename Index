// Calcule les dates de début et fin d'une semaine dans un mois
function getWeekRange(mois, semLabel){
  const d = S.mois[mois];
  const rows = d.rows;
  const MOIS_ABREV={'Septembre':'sep','Octobre':'oct','Novembre':'nov',
    'Décembre':'déc','Janvier':'jan','Février':'fév',
    'Mars':'mar','Avril':'avr','Mai':'mai','Juin':'jun','Juillet':'jul','Aout':'aoû'};
  const abrev = MOIS_ABREV[mois] || mois.substring(0,3).toLowerCase();
  const semaines = [];
  let i = 0;
  while(i < rows.length){
    const debut = rows[i];
    let j = i;
    while(j < rows.length && rows[j].jour !== 'dimanche') j++;
    const fin = rows[Math.min(j, rows.length-1)];
    semaines.push({ debut, fin });
    i = j + 1;
  }
  const semIdx = parseInt(semLabel.replace('S','')) - 1;
  const sem = semaines[semIdx];
  if(!sem) return '';
  const fj = sem.debut.jour.substring(0,3);
  const lj = sem.fin.jour.substring(0,3);
  if(sem.debut.num === sem.fin.num) return `${fj} ${sem.debut.num} ${abrev}`;
  return `${fj} ${sem.debut.num} → ${lj} ${sem.fin.num} ${abrev}`;
}
function upMField(mois,ri,field,val){
  if(!S.mois[mois].rows[ri]) return;
  const r=S.mois[mois].rows[ri]; r[field]=val;
  if(!r.ddate&&(field==='org'||field==='manif'||field==='rem'||field==='clubs')&&val.trim()){
    r.ddate=todayStr();
    const dateEl=document.querySelector(`#dur-${mois}-${ri}`)?.closest('tr')?.querySelector('.cdate');
    if(dateEl) dateEl.textContent=r.ddate;
  }
  const champs=['org','manif','rem','clubs'];
  if(champs.includes(field)){
    const toutVide=champs.every(c=>!(r[c]||'').trim());
    if(toutVide){
      r.ddate='';
      const dateEl=document.querySelector(`#dur-${mois}-${ri}`)?.closest('tr')?.querySelector('.cdate');
      if(dateEl) dateEl.textContent='—';
    }
  }
  if(field==='deb'||field==='fin'){
    const dd=parseInt(r.deb),ff=parseInt(r.fin);
    r.dur=(!isNaN(dd)&&!isNaN(ff)&&ff>dd)?String(ff-dd):'0';
    const el=document.getElementById(`dur-${mois}-${ri}`);
    if(el) el.textContent=r.dur;
  }
  saveM();
}

function autoSync(mois,ri){
  const r=S.mois[mois].rows[ri]; if(!r) return;
  const mi=MOIS.indexOf(mois);
  S.acts_list.forEach(a=>{
    const al=a.toLowerCase();
    const isOrg=r.org&&r.org.toLowerCase().includes(al);
    const idxOrg=S.act[a].findIndex(e=>e.mois===mois&&e.src_ri===ri&&e.type==='org');
    if(isOrg){const en={mois,mois_idx:mi,src_ri:ri,type:'org',manif:r.manif||'',rem:r.rem||''};if(idxOrg>=0)S.act[a][idxOrg]=en;else S.act[a].push(en);}
    else{if(idxOrg>=0)S.act[a].splice(idxOrg,1);}
    const isImp=r.clubs&&r.clubs.toLowerCase().includes(al);
    const idxImp=S.act[a].findIndex(e=>e.mois===mois&&e.src_ri===ri&&e.type==='impact');
    if(isImp){const en={mois,mois_idx:mi,src_ri:ri,type:'impact',manif:r.manif||'',rem:r.rem||''};if(idxImp>=0)S.act[a][idxImp]=en;else S.act[a].push(en);}
    else{if(idxImp>=0)S.act[a].splice(idxImp,1);}
  });
  saveA();
}

function syncAll(){
  S.acts_list.forEach(a=>{S.act[a]=[];});
  MOIS.forEach(mois=>{
    S.mois[mois].rows.forEach((r,ri)=>{
      if(!r) return; const mi=MOIS.indexOf(mois);
      S.acts_list.forEach(a=>{
        const al=a.toLowerCase();
        if(r.org&&r.org.toLowerCase().includes(al)) S.act[a].push({mois,mois_idx:mi,src_ri:ri,type:'org',manif:r.manif||'',rem:r.rem||''});
        if(r.clubs&&r.clubs.toLowerCase().includes(al)) S.act[a].push({mois,mois_idx:mi,src_ri:ri,type:'impact',manif:r.manif||'',rem:r.rem||''});
      });
    });
  });
  saveA();
}

